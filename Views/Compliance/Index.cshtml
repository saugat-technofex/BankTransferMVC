@model BankTransferMVC.Models.RequisiteCheckViewModel
@{
    ViewData["Title"] = "Compliance checks";
}

<cj-feature feature-key="compliance"></cj-feature>

<form asp-action="Check" method="post">
    @Html.AntiForgeryToken()
    <partial name="_CjValidationSummary" />

    <div class="card">
        <div class="card-header">Requisite check <span class="cj-section-hint">POST /v7/gate/checkRequisite/cop &middot; GET /v7/gate/checkRequisite/bankTransfer/eu/iban/{iban}</span></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <cj-label asp-for="Kind"></cj-label>
                    <cj-lookup asp-for="Kind" kind="checkKind" id="kindSelect"></cj-lookup>
                    <cj-help for-key="check.kind"></cj-help>
                </div>
                <div class="col-md-9" data-cj-when="Kind=cop">
                    <cj-label asp-for="Name"></cj-label>
                    <input asp-for="Name" class="form-control" placeholder="Account holder name" />
                    <cj-help for-key="check.copName"></cj-help>
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-3" data-cj-when="Kind=cop">
                    <cj-label asp-for="SortCode"></cj-label>
                    <input asp-for="SortCode" class="form-control" placeholder="000000" maxlength="6" />
                    <span asp-validation-for="SortCode" class="text-danger small"></span>
                </div>
                <div class="col-md-3" data-cj-when="Kind=cop">
                    <cj-label asp-for="AccountNumber"></cj-label>
                    <input asp-for="AccountNumber" class="form-control" placeholder="12345678" maxlength="8" />
                    <span asp-validation-for="AccountNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6" data-cj-when="Kind=cop">
                    <cj-label asp-for="SecondaryReferenceData"></cj-label>
                    <input asp-for="SecondaryReferenceData" class="form-control" placeholder="building society roll number" />
                    <p class="form-text cj-scope small mb-0">Optional &mdash; required only for building society accounts.</p>
                </div>
                <div class="col-md-6" data-cj-when="Kind=iban">
                    <cj-label asp-for="Iban"></cj-label>
                    <input asp-for="Iban" class="form-control" placeholder="DE89370400440532013000" />
                    <cj-help for-key="check.iban"></cj-help>
                    <span asp-validation-for="Iban" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Run check</button>
    <a class="btn btn-link" asp-action="History">History</a>
</form>
