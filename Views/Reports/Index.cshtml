@model BankTransferMVC.Models.TransactionReportViewModel
@{
    ViewData["Title"] = "Transaction report";
}

<cj-feature feature-key="report"></cj-feature>

<form asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <partial name="_CjValidationSummary" />

    <div class="card">
        <div class="card-header">Filters <span class="cj-section-hint">POST /v7/gate/reports/transactionReport</span></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <cj-label asp-for="From"></cj-label>
                    <input asp-for="From" class="form-control" />
                    <span asp-validation-for="From" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <cj-label asp-for="To"></cj-label>
                    <input asp-for="To" class="form-control" />
                    <span asp-validation-for="To" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <cj-label asp-for="WalletUuid"></cj-label>
                    <input asp-for="WalletUuid" class="form-control" placeholder="walletUuid" />
                    <span asp-validation-for="WalletUuid" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <cj-label asp-for="Type"></cj-label>
                    <select asp-for="Type" class="form-select">
                        <option value="all">All</option>
                        <option value="payin">Pay-in</option>
                        <option value="payout">Pay-out</option>
                        <option value="refund">Refund</option>
                        <option value="walletTransfer">Wallet transfer</option>
                        <option value="invoice">Card invoice</option>
                        <option value="instantFxTransfer">Instant FX</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Generate report</button>
    <a class="btn btn-link" asp-action="Events">All webhook events</a>
</form>
