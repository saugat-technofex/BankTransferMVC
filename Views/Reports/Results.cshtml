@model IReadOnlyList<BankTransferMVC.Integrations.ClearJunction.Models.TransactionReportRow>
@{
    ViewData["Title"] = "Report results";
    var form = (BankTransferMVC.Models.TransactionReportViewModel?)ViewBag.Form;
    var mode = (string?)ViewBag.Mode ?? "Simulation";
}

<cj-feature feature-key="report"></cj-feature>

<div class="card">
    <div class="card-header d-flex flex-wrap gap-2 align-items-center">
        <span>
            Results &mdash;
            <code>@form?.From.ToString("yyyy-MM-dd")</code> &rarr;
            <code>@form?.To.ToString("yyyy-MM-dd")</code>
            &middot; type=<code>@form?.Type</code>
            &middot; wallet=<code>@(string.IsNullOrEmpty(form?.WalletUuid) ? "(all)" : form!.WalletUuid)</code>
            &middot; @Model.Count rows
        </span>
        <span class="badge @(mode == "Simulation" ? "bg-info" : "bg-danger") ms-auto">@mode</span>
        <a class="btn btn-sm btn-link" asp-action="Index">New report</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="p-3 text-muted">No transactions in this window.</div>
        }
        else
        {
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Created at</th>
                        <th>Type</th>
                        <th>Client order</th>
                        <th>Order reference</th>
                        <th class="text-end">Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td><code>@r.CreatedAt</code></td>
                        <td><span class="rail-chip">@r.TransactionType</span></td>
                        <td><code>@r.ClientOrder</code></td>
                        <td><code>@r.OrderReference</code></td>
                        <td class="text-end">@r.Amount.ToString("N2") @r.Currency</td>
                        <td><span class="badge-status s-@r.Status">@r.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
