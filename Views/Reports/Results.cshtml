@model IReadOnlyList<BankTransferMVC.Models.WebhookEvent>
@{
    ViewData["Title"] = "Report results";
    var form = (BankTransferMVC.Models.TransactionReportViewModel?)ViewBag.Form;
}

<cj-feature feature-key="report"></cj-feature>

<div class="card">
    <div class="card-header">
        Results — @form?.From.ToString("yyyy-MM-dd") to @form?.To.ToString("yyyy-MM-dd") · type=@form?.Type (@Model.Count rows)
        <a class="btn btn-sm btn-link" asp-action="Index">New report</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="p-3 text-muted">No transactions in this window.</div>
        }
        else
        {
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Type</th>
                        <th>Client order</th>
                        <th>Amount</th>
                        <th>Operational</th>
                        <th>Compliance</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.ReceivedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td><span class="rail-chip">@e.Type</span></td>
                        <td><code>@e.ClientOrder</code></td>
                        <td>@e.Amount.ToString("N2") @e.Currency</td>
                        <td><span class="badge-status s-@e.OperStatus">@e.OperStatus</span></td>
                        <td><span class="badge-status s-@e.ComplianceStatus">@e.ComplianceStatus</span></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
