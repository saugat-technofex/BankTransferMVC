@using BankTransferMVC.Integrations.ClearJunction.Models
@model BankTransferMVC.Models.SettingsViewModel
@{
    ViewData["Title"] = "Settings & integration mode";
    var sim = Model.Simulation;
    var blockers = Model.LivePreflightWarnings.Where(w => w.StartsWith("BLOCKER:")).ToList();
    var warns = Model.LivePreflightWarnings.Where(w => w.StartsWith("WARN:")).ToList();
}

<cj-feature feature-key="settings"></cj-feature>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="card cj-mode-card @(Model.IsSimulation ? "is-sim" : "is-live")">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div>
                <div class="cj-mode-pill">@(Model.IsSimulation ? "SIMULATION MODE" : "LIVE MODE")</div>
                <h5 class="mt-2 mb-1">
                    @(Model.IsSimulation
                        ? "Calls are served by the in-process simulator"
                        : "Calls hit Clear Junction's live REST API")
                </h5>
                <p class="text-muted small mb-0">
                    Last changed @Model.LastChangedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    by <strong>@Model.LastChangedBy</strong>.
                </p>
            </div>
            <div class="text-end small">
                <div><span class="text-muted">Base URL:</span> <code>@Model.BaseUrl</code></div>
                <div><span class="text-muted">API key:</span> <code>@Model.ApiKeyMasked</code></div>
                <div>
                    <span class="text-muted">API password:</span>
                    @if (Model.HasApiPassword)
                    {
                        <span class="badge bg-success">configured</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">not set</span>
                    }
                </div>
                <div><span class="text-muted">Postback:</span> <code>@Model.PostbackBaseUrl</code></div>
                <div>
                    <span class="text-muted">Default wallet:</span>
                    @if (!string.IsNullOrWhiteSpace(Model.DefaultWalletUuid))
                    {
                        <code class="small">@Model.DefaultWalletUuid</code>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">not set</span>
                    }
                </div>
                @if (Model.IsSimulation)
                {
                    <div class="mt-1"><span class="text-muted">Scenario:</span> <code>@sim.Scenario</code></div>
                }
            </div>
        </div>
    </div>
</div>

@if (Model.ConnectivityMessage is not null)
{
    <div class="alert @(Model.ConnectivityOk == true ? "alert-success" : Model.ConnectivityOk == false ? "alert-danger" : "alert-warning") mt-3">
        <strong>Connectivity test:</strong> @Model.ConnectivityMessage
    </div>
}

@if (Model.IsSimulation && (blockers.Any() || warns.Any()))
{
    <div class="alert alert-warning mt-3 mb-0">
        <strong>Live preflight checks</strong> — review these before switching to LIVE mode:
        <ul class="mb-0 small">
            @foreach (var w in blockers)
            {
                <li><span class="badge bg-danger me-1">BLOCKER</span> @w.Replace("BLOCKER:", "")</li>
            }
            @foreach (var w in warns)
            {
                <li><span class="badge bg-warning text-dark me-1">WARN</span> @w.Replace("WARN:", "")</li>
            }
        </ul>
    </div>
}

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Switch mode</div>
            <div class="card-body">
                @if (Model.IsSimulation)
                {
                    <p class="small text-muted mb-2">Going live will start signing requests and sending them to <code>@Model.BaseUrl</code>. Make sure <code>ApiPassword</code> is set to your sandbox secret.</p>
                    <form asp-action="ToggleMode" method="post" class="d-flex flex-column gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TargetMode" value="live" />
                        <input type="text" name="Confirm" class="form-control" placeholder='Type "I UNDERSTAND" to confirm' required />
                        <button type="submit" class="btn btn-warning" @(blockers.Any() ? "disabled" : "")>
                            Switch to LIVE
                        </button>
                        @if (blockers.Any())
                        {
                            <small class="text-danger">Resolve the blockers above to enable this button.</small>
                        }
                    </form>
                }
                else
                {
                    <p class="small text-muted">Switching back to simulation stops all live calls and resumes the in-process fake responses.</p>
                    <form asp-action="ToggleMode" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TargetMode" value="simulation" />
                        <button type="submit" class="btn btn-outline-secondary">Switch to SIMULATION</button>
                    </form>
                    <form asp-action="TestConnectivity" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-primary">Test live connectivity</button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Simulator behaviour</div>
            <div class="card-body">
                <form asp-action="UpdateSimulation" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label">Scenario</label>
                            <select name="Scenario" class="form-select">
                                @foreach (var s in CjScenarios.All)
                                {
                                    <option value="@s.Code" selected="@(sim.Scenario == s.Code)">@s.Label</option>
                                }
                            </select>
                            <small class="text-muted">Applied to every new order and to lifecycle ticks.</small>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Min latency (ms)</label>
                            <input name="MinLatencyMs" type="number" class="form-control" value="@sim.MinLatencyMs" min="0" max="5000" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Max latency (ms)</label>
                            <input name="MaxLatencyMs" type="number" class="form-control" value="@sim.MaxLatencyMs" min="0" max="10000" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Auto-advance interval (s)</label>
                            <input name="AutoAdvanceIntervalSeconds" type="number" class="form-control" value="@sim.AutoAdvanceIntervalSeconds" min="1" max="120" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end gap-3 flex-wrap">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="AutoAdvance" value="true" @(sim.AutoAdvance ? "checked" : "") />
                                <label class="form-check-label">Auto-advance pending orders</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="DeliverWebhooks" value="true" @(sim.DeliverWebhooks ? "checked" : "") />
                                <label class="form-check-label">Deliver simulated webhooks</label>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary mt-3">Save simulator settings</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Simulator state</div>
            <div class="card-body">
                <p class="small text-muted">In-memory ledger snapshot — all data lives in this process and is lost on restart.</p>
                <div class="row row-cols-2 row-cols-md-4 g-2 cj-store-tiles">
                    <div><div class="tile-num">@Model.Store.Wallets</div><div class="tile-lbl">Wallets</div></div>
                    <div><div class="tile-num">@Model.Store.Ibans</div><div class="tile-lbl">vIBANs</div></div>
                    <div><div class="tile-num">@Model.Store.Payouts</div><div class="tile-lbl">Payouts</div></div>
                    <div><div class="tile-num">@Model.Store.Refunds</div><div class="tile-lbl">Refunds</div></div>
                    <div><div class="tile-num">@Model.Store.CardPayins</div><div class="tile-lbl">Card invoices</div></div>
                    <div><div class="tile-num">@Model.Store.Fx</div><div class="tile-lbl">FX trades</div></div>
                    <div><div class="tile-num">@Model.Store.Checks</div><div class="tile-lbl">Compliance checks</div></div>
                    <div><div class="tile-num">@Model.Store.Events</div><div class="tile-lbl">Webhook events</div></div>
                </div>
                <form asp-action="ResetState" method="post" class="mt-3"
                      onsubmit="return confirm('Wipe all in-memory wallets / payouts / events / call log?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm" @(Model.Store.Total == 0 ? "disabled" : "")>
                        Reset simulator state (clears @Model.Store.Total record(s))
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Scenario reference</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 small">
                    <thead>
                        <tr><th>Scenario</th><th>What the simulator does</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>@CjScenarios.Success</code></td>
                            <td>Happy path. New orders <code>pending</code> &rarr; <code>processing</code> &rarr; <code>settled / approved</code>.</td>
                        </tr>
                        <tr>
                            <td><code>@CjScenarios.ComplianceHold</code></td>
                            <td>Operational pipeline advances but compliance stays <code>pending</code> — useful for testing maker-checker approvals.</td>
                        </tr>
                        <tr>
                            <td><code>@CjScenarios.Declined</code></td>
                            <td>Order is declined by operations after submit. CoP returns <code>noMatch</code>.</td>
                        </tr>
                        <tr>
                            <td><code>@CjScenarios.InsufficientFunds</code></td>
                            <td>Wallet transfers fail; payouts go <code>failed/declined</code>.</td>
                        </tr>
                        <tr>
                            <td><code>@CjScenarios.NetworkError</code></td>
                            <td>Every simulated call throws — used to test client-side error handling.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Clear Junction call log <span class="cj-section-hint">most recent 50 — captured in both modes</span></span>
        <form asp-action="ClearCallLog" method="post" class="m-0">
            @Html.AntiForgeryToken()
            <button class="btn btn-sm btn-outline-secondary" type="submit">Clear</button>
        </form>
    </div>
    <div class="card-body p-0">
        @if (!Model.RecentCalls.Any())
        {
            <div class="p-3 text-muted small">No CJ calls captured yet. Submit a payout / FX quote / IBAN allocation to populate the log.</div>
        }
        else
        {
            <table class="table mb-0 small cj-call-log">
                <thead>
                    <tr>
                        <th>When (UTC)</th>
                        <th>Mode</th>
                        <th>Method</th>
                        <th>Path</th>
                        <th>Status</th>
                        <th>Elapsed</th>
                        <th>Detail</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.RecentCalls)
                    {
                        <tr class="@(c.Error is null ? "" : "table-warning")">
                            <td><code>@c.At.UtcDateTime.ToString("HH:mm:ss.fff")</code></td>
                            <td>
                                <span class="badge @(c.Mode == "Simulation" ? "bg-info" : "bg-danger")">@c.Mode</span>
                            </td>
                            <td><code>@c.Method</code></td>
                            <td><code>@c.Path</code></td>
                            <td>@(c.StatusCode?.ToString() ?? "—")</td>
                            <td>@(c.ElapsedMs) ms</td>
                            <td>
                                @if (c.Error is not null)
                                {
                                    <span class="text-danger">@c.Error</span>
                                }
                                else
                                {
                                    <details>
                                        <summary class="small text-muted">request / response</summary>
                                        <pre class="cj-call-pre">@(c.RequestSummary ?? "(no request body)")
─── response ───
@(c.ResponseSummary ?? "(empty)")</pre>
                                    </details>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
