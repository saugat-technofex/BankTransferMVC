@inject Microsoft.Extensions.Options.IOptions<BankTransferMVC.Integrations.ClearJunction.ClearJunctionOptions> CjOptions
@inject BankTransferMVC.Services.ICjModeService CjMode
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clear Junction Console</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/tom-select/tom-select.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BankTransferMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <span class="brand-logo">CJ</span>
                <div>
                    <div class="brand-title">Clear Junction</div>
                    <div class="brand-sub">Bank Transfer Console</div>
                </div>
            </div>

            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                var act = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

                bool RouteIs(string controller, params string[] actions) =>
                    string.Equals(ctrl, controller, StringComparison.OrdinalIgnoreCase)
                    && (actions.Length == 0
                        || actions.Any(a => string.Equals(act, a, StringComparison.OrdinalIgnoreCase)));

                bool CtrlIs(params string[] controllers) =>
                    controllers.Any(c => string.Equals(c, ctrl, StringComparison.OrdinalIgnoreCase));

                string A(string c, params string[] actions) => RouteIs(c, actions) ? "active" : "";

                bool grpAccounts = CtrlIs("Accounts");
                bool grpPayin = CtrlIs("VirtualIban", "Payin");
                bool grpFx = CtrlIs("Fx");
                bool grpPayout = CtrlIs("Payout", "Refund");
                bool grpCompliance = CtrlIs("Compliance");
                bool grpReports = CtrlIs("Reports", "Reference");

                string Show(bool open) => open ? "show" : "";
                string Coll(bool open) => open ? "" : "collapsed";
            }
            <nav class="sidebar-nav">
                <a class="nav-link nav-top @A("Home", "Index", "Privacy")" asp-controller="Home" asp-action="Index">
                    <span class="nav-ico">&#9632;</span> Dashboard
                </a>

                <button class="nav-group-toggle @Coll(grpAccounts) @(grpAccounts ? "active-group" : "")" data-bs-toggle="collapse" data-bs-target="#grp-accounts" aria-expanded="@(grpAccounts ? "true" : "false")">
                    <span class="nav-ico">&#9783;</span> Accounts <span class="caret">&rsaquo;</span>
                </button>
                <div id="grp-accounts" class="collapse @Show(grpAccounts)">
                    <a class="nav-link sub @A("Accounts", "Index", "Details", "Statement", "Create")" asp-controller="Accounts" asp-action="Index">Wallets</a>
                    <a class="nav-link sub @A("Accounts", "Transfer")" asp-controller="Accounts" asp-action="Transfer">Internal transfer</a>
                </div>

                <button class="nav-group-toggle @Coll(grpPayin) @(grpPayin ? "active-group" : "")" data-bs-toggle="collapse" data-bs-target="#grp-payin" aria-expanded="@(grpPayin ? "true" : "false")">
                    <span class="nav-ico">&#8595;</span> Pay-in <span class="caret">&rsaquo;</span>
                </button>
                <div id="grp-payin" class="collapse @Show(grpPayin)">
                    <a class="nav-link sub @A("VirtualIban", "Index", "Details", "Create")" asp-controller="VirtualIban" asp-action="Index">Virtual IBANs</a>
                    <a class="nav-link sub @A("Payin", "Index", "Simulate")" asp-controller="Payin" asp-action="Index">Bank pay-in events</a>
                    <a class="nav-link sub @A("Payin", "CardList", "Card")" asp-controller="Payin" asp-action="CardList">Card invoices</a>
                </div>

                <button class="nav-group-toggle @Coll(grpFx) @(grpFx ? "active-group" : "")" data-bs-toggle="collapse" data-bs-target="#grp-fx" aria-expanded="@(grpFx ? "true" : "false")">
                    <span class="nav-ico">&#8644;</span> Multi-currency <span class="caret">&rsaquo;</span>
                </button>
                <div id="grp-fx" class="collapse @Show(grpFx)">
                    <a class="nav-link sub @A("Fx", "Index", "Quote", "Execute")" asp-controller="Fx" asp-action="Index">FX quote &amp; convert</a>
                    <a class="nav-link sub @A("Fx", "History")" asp-controller="Fx" asp-action="History">FX history</a>
                </div>

                <button class="nav-group-toggle @Coll(grpPayout) @(grpPayout ? "active-group" : "")" data-bs-toggle="collapse" data-bs-target="#grp-payout" aria-expanded="@(grpPayout ? "true" : "false")">
                    <span class="nav-ico">&#8593;</span> Pay-out &amp; refund <span class="caret">&rsaquo;</span>
                </button>
                <div id="grp-payout" class="collapse @Show(grpPayout)">
                    <a class="nav-link sub @A("Payout", "Index", "Details", "Refresh", "Create")" asp-controller="Payout" asp-action="Index">Payouts</a>
                    <a class="nav-link sub @A("Refund", "Index", "Create")" asp-controller="Refund" asp-action="Index">Refunds</a>
                </div>

                <button class="nav-group-toggle @Coll(grpCompliance) @(grpCompliance ? "active-group" : "")" data-bs-toggle="collapse" data-bs-target="#grp-compliance" aria-expanded="@(grpCompliance ? "true" : "false")">
                    <span class="nav-ico">&#9873;</span> Compliance <span class="caret">&rsaquo;</span>
                </button>
                <div id="grp-compliance" class="collapse @Show(grpCompliance)">
                    <a class="nav-link sub @A("Compliance", "Index", "Check")" asp-controller="Compliance" asp-action="Index">Requisite checks</a>
                    <a class="nav-link sub @A("Compliance", "History")" asp-controller="Compliance" asp-action="History">Check history</a>
                    <a class="nav-link sub @A("Compliance", "Approvals", "Approve", "Cancel")" asp-controller="Compliance" asp-action="Approvals">Maker-checker approvals</a>
                </div>

                <button class="nav-group-toggle @Coll(grpReports) @(grpReports ? "active-group" : "")" data-bs-toggle="collapse" data-bs-target="#grp-reports" aria-expanded="@(grpReports ? "true" : "false")">
                    <span class="nav-ico">&#9783;</span> Reports &amp; events <span class="caret">&rsaquo;</span>
                </button>
                <div id="grp-reports" class="collapse @Show(grpReports)">
                    <a class="nav-link sub @A("Reports", "Index", "Results")" asp-controller="Reports" asp-action="Index">Transaction report</a>
                    <a class="nav-link sub @A("Reports", "Events")" asp-controller="Reports" asp-action="Events">Webhook events</a>
                    <a class="nav-link sub @A("Reference", "Index")" asp-controller="Reference" asp-action="Index">Reference catalog</a>
                </div>

                <a class="nav-link nav-top @A("Settings", "Index", "ToggleMode", "UpdateSimulation", "TestConnectivity", "ClearCallLog", "ResetState")" asp-controller="Settings" asp-action="Index">
                    <span class="nav-ico">&#9881;</span> Settings &amp; mode
                </a>
            </nav>

            <div class="sidebar-footer">
                <a class="env-pill-link" asp-controller="Settings" asp-action="Index" title="Open mode settings">
                    <div class="env-pill @(CjMode.IsSimulation ? "env-sim" : "env-live")">
                        @(CjMode.IsSimulation ? "SIMULATION MODE" : "LIVE MODE")
                    </div>
                </a>
                <div class="env-host" title="@CjOptions.Value.BaseUrl">@CjOptions.Value.BaseUrl</div>
                @if (CjMode.IsSimulation && CjMode.Simulation.Scenario != "success")
                {
                    <div class="env-scenario">scenario: @CjMode.Simulation.Scenario</div>
                }
            </div>
        </aside>

        <main class="main">
            @if (!CjMode.IsSimulation)
            {
                <div class="live-banner" role="alert">
                    <strong>LIVE MODE</strong> &mdash; every action below calls Clear Junction's real API with signed requests.
                    <a asp-controller="Settings" asp-action="Index" class="ms-2">Switch back to Simulation</a>
                </div>
            }
            <header class="topbar">
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-meta">
                    v7 gate &middot; @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm 'UTC'") &middot;
                    <span class="@(CjMode.IsSimulation ? "text-info" : "text-danger") fw-semibold">
                        @(CjMode.IsSimulation ? "simulator" : "live")
                    </span>
                </div>
            </header>

            @if (TempData["Success"] is string ok)
            {
                <div class="alert alert-success" role="alert">@ok</div>
            }
            @if (TempData["Error"] is string err)
            {
                <div class="alert alert-danger" role="alert">@err</div>
            }

            <div class="content">
                @RenderBody()
            </div>

            <footer class="page-footer">
                Clear Junction REST API v7 ? Demo console &middot; Use sandbox credentials only.
            </footer>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/tom-select/tom-select.complete.min.js"></script>
    <script src="~/js/cj-validators.js" asp-append-version="true"></script>
    <script src="~/js/cj-lookup.js" asp-append-version="true"></script>
    <script src="~/js/cj-conditions.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
