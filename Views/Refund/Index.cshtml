@model IReadOnlyList<BankTransferMVC.Models.RefundRecord>
@{
    ViewData["Title"] = "Refunds";
}

<cj-feature feature-key="refund"></cj-feature>

<div class="card">
    <div class="card-header">
        Refunds (@Model.Count)
        <a class="btn btn-sm btn-primary" asp-action="Create">New refund</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="p-3 text-muted">No refunds yet. Refunds use <code>/v7/gate/refund</code> for incoming + outgoing flows.</div>
        }
        else
        {
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Created</th>
                        <th>Client order</th>
                        <th>Direction</th>
                        <th>Original order</th>
                        <th>Amount</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Operational</th>
                        <th>Compliance</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.CreatedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td><code>@r.ClientOrder</code></td>
                        <td><span class="rail-chip">@r.Direction</span></td>
                        <td><code>@r.OriginalClientOrder</code></td>
                        <td>@r.Amount.ToString("N2") @r.Currency</td>
                        <td>@r.Reason</td>
                        <td><span class="badge-status s-@r.Status">@r.Status</span></td>
                        <td><span class="badge-status s-@r.OperStatus">@r.OperStatus</span></td>
                        <td><span class="badge-status s-@r.ComplianceStatus">@r.ComplianceStatus</span></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
