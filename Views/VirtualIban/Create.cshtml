@model BankTransferMVC.Models.CreateIbanViewModel
@{
    ViewData["Title"] = "Allocate Virtual IBAN";
}

<cj-feature feature-key="virtualIbanCreate"></cj-feature>

<partial name="_PageBack" view-data='new ViewDataDictionary(ViewData) {
    { "BackController", "VirtualIban" },
    { "BackAction", "Index" },
    { "BackLabel", "Back to Virtual IBANs" }
}' />

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <partial name="_CjValidationSummary" />

    <div class="card">
        <div class="card-header">Registrant <span class="cj-section-hint">registrant entity (POST /v7/gate/allocate/v3/create/iban)</span></div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <cj-label asp-for="ClientCustomerId"></cj-label>
                    <partial name="_AutoCustomerId" view-data='new ViewDataDictionary(ViewData) {
                        ["AspFor"] = "ClientCustomerId",
                        ["CurrentValue"] = Model.ClientCustomerId,
                        ["HelpKey"] = "iban.clientCustomerId",
                        ["RegenerateUrl"] = Url.Action("Create", new { regenerate = true }),
                        ["ExistingIds"] = (IEnumerable<string>?)ViewBag.ExistingCustomerIds ?? Enumerable.Empty<string>()
                    }' />
                    <span asp-validation-for="ClientCustomerId" class="text-danger small"></span>
                </div>
            </div>

            <label class="form-label">Entity type</label>
            <div class="cj-radio-group mb-2">
                <label><input type="radio" asp-for="Registrant.EntityType" value="individual" /> Individual</label>
                <label><input type="radio" asp-for="Registrant.EntityType" value="corporate" /> Corporate</label>
            </div>

            <div data-cj-when="Registrant.EntityType=individual" class="cj-entity-block">
                <partial name="_CjIndividual" for="Registrant" />
            </div>
            <div data-cj-when="Registrant.EntityType=corporate" class="cj-entity-block cj-block-corporate">
                <partial name="_CjCorporate" for="Registrant" />
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Registrant address <span class="cj-section-hint">registrant.{individual|corporate}.address</span></div>
        <div class="card-body">
            <partial name="_CjAddress" for="Registrant" />
        </div>
    </div>

    <div class="card">
        <div class="card-header">IBAN options <span class="cj-section-hint">walletUuid auto-generated on submit</span></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <cj-label asp-for="IbanCountry"></cj-label>
                    <cj-lookup asp-for="IbanCountry" kind="country" remote="true" placeholder="Search IBAN country..."></cj-lookup>
                    <cj-help for-key="iban.ibanCountry"></cj-help>
                </div>
                <div class="col-md-4">
                    <cj-label asp-for="IbansGroup"></cj-label>
                    <cj-lookup asp-for="IbansGroup" kind="ibansGroup" placeholder="Select IBAN pool..."></cj-lookup>
                    <cj-help for-key="iban.ibansGroup"></cj-help>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Allocate IBAN</button>
        <a class="btn btn-link" asp-action="Index">Cancel</a>
    </div>
</form>
