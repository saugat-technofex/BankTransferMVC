@model BankTransferMVC.Models.FxQuoteViewModel
@{
    ViewData["Title"] = "FX quote & convert";
}

<cj-feature feature-key="fx"></cj-feature>

<div class="row g-3">
    <div class="col-lg-7">
        <form asp-action="Quote" method="post">
            @Html.AntiForgeryToken()
            <partial name="_CjValidationSummary" />
            <div class="card">
                <div class="card-header">Request a quote</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <cj-label asp-for="SellCurrency" text="Sell"></cj-label>
                            <cj-lookup asp-for="SellCurrency" kind="currency" placeholder="Search sell currency..."></cj-lookup>
                            <cj-help for-key="fx.sellCurrency"></cj-help>
                            <span asp-validation-for="SellCurrency" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <cj-label asp-for="BuyCurrency" text="Buy"></cj-label>
                            <cj-lookup asp-for="BuyCurrency" kind="currency" placeholder="Search buy currency..."></cj-lookup>
                            <cj-help for-key="fx.buyCurrency"></cj-help>
                            <span asp-validation-for="BuyCurrency" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <cj-label asp-for="SellAmount" text="Sell amount"></cj-label>
                            <input asp-for="SellAmount" class="form-control" />
                            <cj-help for-key="fx.sellAmount"></cj-help>
                            <span asp-validation-for="SellAmount" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-outline-primary">Get rate</button>
        </form>

        @if (!string.IsNullOrEmpty(Model.RateUuid))
        {
            <form asp-action="Execute" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SellCurrency" />
                <input type="hidden" asp-for="BuyCurrency" />
                <input type="hidden" asp-for="SellAmount" />
                <input type="hidden" asp-for="BuyAmount" />
                <input type="hidden" asp-for="Rate" />
                <input type="hidden" asp-for="RateUuid" />
                <input type="hidden" asp-for="ExpirationTimestamp" />

                <div class="card">
                    <div class="card-header">Quote &mdash; execute before expiry</div>
                    <div class="card-body">
                        <dl class="row mb-2">
                            <dt class="col-sm-4">Rate</dt>
                            <dd class="col-sm-8">1 @Model.SellCurrency = @Model.Rate @Model.BuyCurrency</dd>
                            <dt class="col-sm-4">You sell</dt>
                            <dd class="col-sm-8">@Model.SellAmount.ToString("N2") @Model.SellCurrency</dd>
                            <dt class="col-sm-4">You receive</dt>
                            <dd class="col-sm-8">
                                @Model.BuyAmount?.ToString("N2") @Model.BuyCurrency
                                <partial name="_CjDetailNote" model="@("fx.buyAmount")" />
                            </dd>
                            <dt class="col-sm-4">Rate UUID</dt>
                            <dd class="col-sm-8">
                                <code>@Model.RateUuid</code>
                                <partial name="_CjDetailNote" model="@("fx.rateUuid")" />
                            </dd>
                            <dt class="col-sm-4">Expires</dt>
                            <dd class="col-sm-8">@Model.ExpirationTimestamp</dd>
                        </dl>
                        <button type="submit" class="btn btn-primary">Execute conversion</button>
                    </div>
                </div>
            </form>
        }
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">When do I use FX?</div>
            <div class="card-body">
                <ul class="small text-muted mb-0">
                    <li>Collected EUR via SEPA but need to pay out USD via SWIFT.</li>
                    <li>Received an inbound SWIFT in USD and need GBP for a Faster Payments payout.</li>
                    <li>Convert between any two currencies held in your Clear Junction wallet.</li>
                </ul>
            </div>
        </div>
        <div class="card">
            <div class="card-header">Limits (typical)</div>
            <div class="card-body small text-muted">
                Min &approx; 500 EUR &middot; Max &approx; 200,000 EUR per trade &middot; Daily &approx; 1,000,000 EUR &middot; ~06:00&ndash;15:00 UK.
            </div>
        </div>
    </div>
</div>
