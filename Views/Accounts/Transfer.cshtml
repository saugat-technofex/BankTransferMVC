@model BankTransferMVC.Models.WalletTransferViewModel
@{
    ViewData["Title"] = "Wallet transfer";
    var wallets = (IReadOnlyList<BankTransferMVC.Models.WalletRecord>?)ViewBag.Wallets
        ?? new List<BankTransferMVC.Models.WalletRecord>();
}

<cj-feature feature-key="walletTransfer"></cj-feature>

<partial name="_PageBack" view-data='new ViewDataDictionary(ViewData) {
    { "BackController", "Accounts" },
    { "BackAction", "Index" },
    { "BackLabel", "Back to Wallets" }
}' />

<form asp-action="Transfer" method="post">
    @Html.AntiForgeryToken()
    <partial name="_CjValidationSummary" />

    <div class="card">
        <div class="card-header">Internal transfer <span class="cj-section-hint">POST /v7/gate/wallets/transfer</span></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <cj-label asp-for="FromWalletUuid"></cj-label>
                    <select asp-for="FromWalletUuid" class="form-select" required>
                        <option value="">-- select source wallet --</option>
                        @foreach (var w in wallets)
                        {
                            <option value="@w.WalletUuid">@w.Name (@w.Currency @w.Balance.ToString("N2"))</option>
                        }
                    </select>
                    <cj-help for-key="walletTransfer.from"></cj-help>
                    <span asp-validation-for="FromWalletUuid" class="text-danger small"></span>
                </div>
                <div class="col-md-5">
                    <cj-label asp-for="ToWalletUuid"></cj-label>
                    <select asp-for="ToWalletUuid" class="form-select" required>
                        <option value="">-- select destination wallet --</option>
                        @foreach (var w in wallets)
                        {
                            <option value="@w.WalletUuid">@w.Name (@w.Currency @w.Balance.ToString("N2"))</option>
                        }
                    </select>
                    <cj-help for-key="walletTransfer.to"></cj-help>
                    <span asp-validation-for="ToWalletUuid" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <cj-label asp-for="Currency"></cj-label>
                    <cj-lookup asp-for="Currency" kind="currency" placeholder="Currency..."></cj-lookup>
                </div>
                <div class="col-md-3">
                    <cj-label asp-for="Amount"></cj-label>
                    <input asp-for="Amount" class="form-control" />
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
                <div class="col-md-9">
                    <cj-label asp-for="Reference"></cj-label>
                    <input asp-for="Reference" class="form-control" />
                    <span asp-validation-for="Reference" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary" disabled="@(!wallets.Any())">Transfer</button>
    <a class="btn btn-link" asp-action="Index">Cancel</a>
</form>
